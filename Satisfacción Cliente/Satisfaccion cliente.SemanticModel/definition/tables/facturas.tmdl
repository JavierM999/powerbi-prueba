	measure 'Clientes Perdidos' = ```
			
			IF(NOT(MIN(Calendario[Date]) > CALCULATE(MAX(Facturas[fcfecha]), ALL(Facturas))),
			    VAR primeraFecha = FIRSTDATE(Calendario[Date])
			    VAR tabla = FILTER(
			                        ALL(Calendario),
			                        Calendario[Date] >= DATEADD(primeraFecha, -1, YEAR) && Calendario[Date] <= MAX(Calendario[Date]) 
			                    )
			    RETURN
			    COUNTROWS(
			        FILTER(
			            ADDCOLUMNS(
			                CALCULATETABLE(
			                    VALUES(facturas[FraCenCli]),
			                    tabla
			                ),
			                "FechaUltimaFactura", CALCULATE(MAX(Facturas[fcfecha]))
			            ),
			            [FechaUltimaFactura] < primeraFecha
			        )
			    )
			)
			
			```
		formatString: 0
		lineageTag: 52ae071a-41d0-431e-a0f9-92cd2c751696

	measure 'Clientes Nuevos' = ```
			
			IF(NOT(MIN(Calendario[Date]) > CALCULATE(MAX(Facturas[fcfecha]), ALL(Facturas))),
			    VAR primeraFecha = FIRSTDATE(Calendario[Date])
			    VAR tabla = FILTER(
			                        ALL(Calendario),
			                        Calendario[Date] >= DATEADD(primeraFecha, -1, YEAR) && Calendario[Date] <= MAX(Calendario[Date]) 
			                    )
			    RETURN
			    COUNTROWS(
			        FILTER(
			            ADDCOLUMNS(
			                CALCULATETABLE(
			                    VALUES(facturas[FraCenCli]),
			                    tabla
			                ),
			                "FechaPrimFactura", CALCULATE(MIN(Facturas[fcfecha]), tabla)
			            ),
			            [FechaPrimFactura] >= primeraFecha
			        )
			    )
			)
			```
		formatString: 0
		lineageTag: 04565bc2-6685-4d3d-972b-45c7cd806a42

	measure 'Clientes Perdidos2' = ```
			
			VAR ClientesPrimPeriodo =
			    CALCULATETABLE (
			        VALUES ( facturas[FraCenCli] ),
			        FILTER (
			            ALL ( Calendario ),
			            Calendario[Date]
			                > MIN ( Calendario[Date] ) - 730
			                && Calendario[Date]
			                    < MIN ( Calendario[Date] ) - 240
			        )
			    )
			VAR ClientesSegPeriodo =
			    CALCULATETABLE (
			        VALUES ( facturas[FraCenCli] ),
			        FILTER (
			            ALL ( Calendario ),
			            Calendario[Date]
			                > MIN ( Calendario[Date] ) - 240
			                && Calendario[Date] < MIN ( Calendario[Date] )
			        )
			    )
			RETURN
			    COUNTROWS ( EXCEPT ( ClientesPrimPeriodo, ClientesSegPeriodo ) )
			
			```
		formatString: 0
		lineageTag: 299a2399-9331-4536-838f-4168b1f09443

	measure 'Fra Clientes Perdidos2' =
			
			VAR ClientesPrimPeriodo =
			    CALCULATETABLE (
			        VALUES ( facturas[FraCenCli] ),
			        FILTER (
			            ALL ( Calendario ),
			            Calendario[Date]
			                > MIN ( Calendario[Date] ) - 730
			                && Calendario[Date]
			                    < MIN ( Calendario[Date] ) - 240
			        )
			    )
			VAR ClientesSegPeriodo =
			    CALCULATETABLE (
			        VALUES ( facturas[FraCenCli] ),
			        FILTER (
			            ALL ( Calendario ),
			            Calendario[Date]
			                > MIN ( Calendario[Date] ) - 240
			                && Calendario[Date] < MIN ( Calendario[Date] )
			        )
			    )
			RETURN
			    CALCULATE([TotFra],
			    DATESBETWEEN(Calendario[Date],MIN(Calendario[Date]) - 730, MIN ( Calendario[Date] ) - 240),
			    EXCEPT ( ClientesPrimPeriodo, ClientesSegPeriodo )
			)
		formatString: #,0.00
		lineageTag: 0e39e57b-5d20-43ec-b6d1-1ef49a77cffa

