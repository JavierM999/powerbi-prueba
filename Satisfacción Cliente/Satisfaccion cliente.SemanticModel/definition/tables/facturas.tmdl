	measure 'ClientesPerdidos gpt' = ```
			
			VAR primeraFecha = FIRSTDATE(Calendario[Date])
			VAR clientesAnioActual =
			    CALCULATETABLE(
			        VALUES(Facturas[FraCenCli]),
			        FILTER(
			            ALL(Calendario),
			            Calendario[Date] >= primeraFecha && Calendario[Date] <= MAX(Calendario[Date])
			        )
			    )
			VAR clientesAnioPasado =
			    CALCULATETABLE(
			        VALUES(Facturas[FraCenCli]),
			        FILTER(
			            ALL(Calendario),
			            Calendario[Date] >= DATEADD(primeraFecha, -1, YEAR) && Calendario[Date] < primeraFecha
			        )
			    )
			VAR clientesFacturacionNegativa =
			    FILTER(
			        clientesAnioActual,
			        CALCULATE(SUM(MovFra[TMFra])) <= 0
			    )
			RETURN
			    COUNTROWS(
			        EXCEPT(
			            clientesAnioPasado,
			            UNION(clientesAnioActual, clientesFacturacionNegativa)
			        )
			    )
			
			```
		formatString: 0
		lineageTag: 9323168e-0967-4040-a377-368cd5c0c09d

