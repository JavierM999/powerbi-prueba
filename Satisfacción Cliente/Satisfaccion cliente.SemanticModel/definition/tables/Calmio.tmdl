	partition Calmio-cde8e7c8-bff8-462c-af49-e1c8055d1551 = calculated
		mode: import
		source = ```
				
				var primerafecha = DATE(2022,03,01)
				return  
				FILTER(
				                        ALL(Calendario),
				                        Calendario[Date] >=primerafecha && Calendario[Date] <= MAX(Calendario[Date]) 
				                    )
				```

	annotation PBI_Id = ddb627428b5743cfad2524760d7ecc1c

