	partition MovFra-292ca2ea-5a26-4f7d-9c7b-2d417a475deb = m
		mode: import
		source =
				let
				    Origen = Sql.Database("10.10.138.5\temporing", "no3001", [Query="select movtos.mvempresa,movtos.mvcentro,movtos.mvcliente,movtos.mvcpd,movtos.mvtrabajador,movtos.mvunidad,movtos.mvprecio,facturas.fcfecha#(lf)from movtos inner join#(lf)       facturas on movtos.mvempresa=facturas.fcempresa and movtos.mvseriefac=facturas.fcserie and#(lf)#(tab)          movtos.mvnumerofac=facturas.fcdocum and movtos.mvanofac=facturas.fcano#(lf)where movtos.mvempresa=1#(lf)and YEAR(facturas.fcfecha) >= (YEAR(GETDATE()) - 2)#(lf)and mvfacturada='S'"]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(Origen,{{"fcfecha", type date}, {"mvcentro", Int64.Type}, {"mvempresa", Int64.Type}})
				in
				    #"Tipo cambiado"

	annotation PBI_ResultType = Table

