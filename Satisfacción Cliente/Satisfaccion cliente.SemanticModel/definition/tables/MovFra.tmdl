	measure 'Clientes Perdidos MCA' =
			
			VAR AnioSeleccionado = SELECTEDVALUE(Calendario[Año])
			VAR AnioAnterior = AnioSeleccionado - 1
			RETURN
			IF(
			    ISBLANK(AnioSeleccionado),
			    BLANK(),
			    COUNTROWS(
			        FILTER(
			            ALL(MovFra[FraCenCli]),
			            CALCULATE(
			                SUM(MovFra[TMFra]),
			                REMOVEFILTERS(Calendario),
			                Calendario[Año] = AnioAnterior
			            ) > 0
			            &&
			            CALCULATE(
			                SUM(MovFra[TMFra]),
			                REMOVEFILTERS(Calendario),
			                Calendario[Año] = AnioSeleccionado
			            ) <= 0
			        )
			    )
			)
		formatString: 0
		lineageTag: 97625fc2-1fb9-43ed-af80-1bfbb909173f

	measure 'FraCli Perdidos ant' = ```
			
			VAR ClientesTotFraActual =
			    FILTER(
			        ALL(MovFra[FraCenCli]),
			        CALCULATE(
			            SUM(MovFra[TMFra]),
			            REMOVEFILTERS(Calendario),
			            Calendario[Año] = 2024
			        ) <=0
			    )
			VAR ClientesTotFraAnterior =
			    FILTER(
			        ALL(MovFra[FraCenCli]),
			        CALCULATE(
			            SUM(MovFra[TMFra]),
			            REMOVEFILTERS(Calendario),
			            Calendario[Año] = 2023
			        ) > 0
			    )
			VAR ClientesCruzados =
			    INTERSECT(ClientesTotFraActual, ClientesTotFraAnterior)
			RETURN
			    SUMX(
			        ClientesCruzados,
			        CALCULATE(
			            SUM(MovFra[TMFra]),
			            REMOVEFILTERS(Calendario),
			            Calendario[Año] = 2023
			        )
			    )
			
			```
		formatString: #,0.00
		lineageTag: 3d31c3ec-5b00-44c9-97df-6b20e279389c

	measure AsignacionesClientesPerdidos = ```
			
			VAR AnioSeleccionado = SELECTEDVALUE(Calendario[Año])
			VAR AnioAnterior = AnioSeleccionado - 1
			VAR FechaInicioAnioAnterior = DATE(AnioAnterior, 1, 1)
			VAR FechaFinAnioAnterior = DATE(AnioAnterior, 12, 31)
			
			VAR ClientesPerdidos = 
			    FILTER(
			        ALL(MovFra[FraCenCli]),
			        CALCULATE(
			            SUM(MovFra[TMFra]),
			            REMOVEFILTERS(Calendario),
			            Calendario[Año] = AnioAnterior
			        ) > 0
			        &&
			        CALCULATE(
			            SUM(MovFra[TMFra]),
			            REMOVEFILTERS(Calendario),
			            Calendario[Año] = AnioSeleccionado
			        ) <= 0
			    )
			
			VAR TotalAsignaciones =
			    SUMX(
			        ClientesPerdidos,
			        VAR ClienteActual = MovFra[FraCenCli]
			        RETURN
			            CALCULATE(
			                COUNTROWS(Contratos),
			                FILTER(
			                    ALL(Contratos),
			                    Contratos[ConCenCli] = ClienteActual
			                        && Contratos[ctfechaini] <= FechaFinAnioAnterior
			                        && (
			                            ISBLANK(Contratos[ctfechafinreal])
			                            || Contratos[ctfechafinreal] >= FechaInicioAnioAnterior
			                        )
			                )
			            )
			    )
			
			RETURN
			IF(
			    ISBLANK(AnioSeleccionado),
			    BLANK(),
			    TotalAsignaciones
			)
			
			
			```
		formatString: #,0
		lineageTag: 634f1d99-b347-4da3-b62c-08ea63d8fbe9

	measure 'FraCli Perdidos' = ```
			
			VAR AnioSeleccionado = SELECTEDVALUE(Calendario[Año])
			VAR AnioAnterior = AnioSeleccionado - 1
			RETURN
			IF(
			    ISBLANK(AnioSeleccionado),
			    BLANK(),
			    SUMX(
			        FILTER(
			            ALL(MovFra[FraCenCli]),
			            CALCULATE(
			                SUM(MovFra[TMFra]),
			                REMOVEFILTERS(Calendario),
			                Calendario[Año] = AnioAnterior
			            ) > 0
			            &&
			            CALCULATE(
			                SUM(MovFra[TMFra]),
			                REMOVEFILTERS(Calendario),
			                Calendario[Año] = AnioSeleccionado
			            ) <= 0
			        ),
			        CALCULATE(
			            SUM(MovFra[TMFra]),
			            REMOVEFILTERS(Calendario),
			            Calendario[Año] = AnioAnterior
			        )
			    )
			)
			
			```
		formatString: #,0.00
		lineageTag: 02a957e0-8cf4-457b-88cb-b35e81cf40b7

