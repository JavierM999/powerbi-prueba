	partition OFlineas = m
		mode: import
		source =
				let
				    Origen = Sql.Database("10.10.138.5\TEMPORING", "no3001", [Query="select ofcentro,ofcodigo,oflcatepuesto,ofestado,offechaoferta,oflepigrafe,oflporcmargen,ofltarifahora,ofltarifames,ofltarifa7dias,oflsalariohora,oflsalariomes,oflcoefhora,oflcoefhora7dias,oflcoefmes,oflcatesalario#(lf)#(tab)oflporcmargenhora,oflporcmargenmes,oflporcmargen7dias#(lf)from oferta INNER JOIN#(lf)                      oflineas ON oferta.ofempresa = oflineas.oflempresa AND oferta.ofcentro = oflineas.oflcentro AND oferta.ofcodigo = oflineas.oflcodigo#(lf)where oflempresa=1#(lf)and year(offechaoferta)>=2018"]),
				    #"Tipo cambiado1" = Table.TransformColumnTypes(Origen,{{"offechaoferta", type date}}),
				    #"Tipo cambiado" = Table.TransformColumnTypes(#"Tipo cambiado1",{{"ofcentro", Int64.Type}, {"ofcodigo", Int64.Type}, {"oflcatepuesto", Int64.Type}}),
				    Redondeado = Table.TransformColumns(#"Tipo cambiado",{{"oflcoefhora", each Number.Round(_, 3), type number}})
				in
				    Redondeado

	annotation PBI_QueryRelationships = {"columnCount":18,"keyColumnNames":[],"queryRelationships":[],"columnIdentities":["Section1/OFlineas/Tipo cambiado.{ofcentro,0}","Section1/OFlineas/Tipo cambiado.{ofcodigo,1}","Section1/OFlineas/Tipo cambiado.{oflcatepuesto,2}","Section1/OFlineas/Origen.{ofestado,3}","Section1/OFlineas/Tipo cambiado1.{offechaoferta,4}","Section1/OFlineas/Origen.{oflepigrafe,5}","Section1/OFlineas/Origen.{oflporcmargen,6}","Section1/OFlineas/Origen.{ofltarifahora,7}","Section1/OFlineas/Origen.{ofltarifames,8}","Section1/OFlineas/Origen.{ofltarifa7dias,9}","Section1/OFlineas/Origen.{oflsalariohora,10}","Section1/OFlineas/Origen.{oflsalariomes,11}","Section1/OFlineas/Redondeado.{oflcoefhora,12}","Section1/OFlineas/Origen.{oflcoefhora7dias,13}","Section1/OFlineas/Origen.{oflcoefmes,14}","Section1/OFlineas/Origen.{oflporcmargenhora,15}","Section1/OFlineas/Origen.{oflporcmargenmes,16}","Section1/OFlineas/Origen.{oflporcmargen7dias,17}"],"ColumnCount":18,"KeyColumnNames":[],"ColumnIdentities":["Section1/OFlineas/Tipo cambiado.{ofcentro,0}","Section1/OFlineas/Tipo cambiado.{ofcodigo,1}","Section1/OFlineas/Tipo cambiado.{oflcatepuesto,2}","Section1/OFlineas/Origen.{ofestado,3}","Section1/OFlineas/Tipo cambiado1.{offechaoferta,4}","Section1/OFlineas/Origen.{oflepigrafe,5}","Section1/OFlineas/Origen.{oflporcmargen,6}","Section1/OFlineas/Origen.{ofltarifahora,7}","Section1/OFlineas/Origen.{ofltarifames,8}","Section1/OFlineas/Origen.{ofltarifa7dias,9}","Section1/OFlineas/Origen.{oflsalariohora,10}","Section1/OFlineas/Origen.{oflsalariomes,11}","Section1/OFlineas/Redondeado.{oflcoefhora,12}","Section1/OFlineas/Origen.{oflcoefhora7dias,13}","Section1/OFlineas/Origen.{oflcoefmes,14}","Section1/OFlineas/Origen.{oflporcmargenhora,15}","Section1/OFlineas/Origen.{oflporcmargenmes,16}","Section1/OFlineas/Origen.{oflporcmargen7dias,17}"],"RelationshipInfo":[]}

