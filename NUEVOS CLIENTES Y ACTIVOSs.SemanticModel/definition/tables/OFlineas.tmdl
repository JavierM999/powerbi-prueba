	measure 'Ofertas Totales' = CALCULATE(DISTINCTCOUNT(OFlineas[ofcodigo]),FILTER(OFlineas,OFlineas[offechaoferta]>=[fecini]),FILTER(OFlineas,OFlineas[offechaoferta]<=[fecfin]))
