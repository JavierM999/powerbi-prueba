table contratos
	lineageTag: 56dbfa82-3c8c-4223-bbdb-bedd38da07e3

	measure Asignaciones = CALCULATE(COUNTROWS(Contratos),FILTER(Contratos,Contratos[ctfechaini]<=[fecfin]),FILTER(Contratos,  ISBLANK(Contratos[ctfechafinreal])=TRUE() || Contratos[ctfechafinreal]>=[fecini]))
		formatString: 0
		lineageTag: f28c91a0-9520-431f-98f7-f13da62e8078

	measure AvWeek = AVERAGEX(VALUES(Calendario[Date]),[Asignaciones])
		formatString: 0
		lineageTag: f75fd6b1-aa30-4852-a28f-b2be6396c0a4

	measure FraXAsig = [TotFraCN3]/[AvWeek]
		formatString: #,0.00
		lineageTag: c811df0c-e4f9-4a08-8a74-0d492c013c8c

	measure 'AvLastWeek nochuta' = CALCULATE(AVERAGEX(VALUES(Calendario[Date]),[AsignaAnyoMA]))
		formatString: 0
		lineageTag: b33aab6d-8a4c-4adb-9858-bf36b8a1219c

	measure AsignaAnyoMA = CALCULATE(COUNTROWS(Contratos),FILTER(Contratos,Contratos[ctfechaini]<=[fecfinma]),FILTER(Contratos,  ISBLANK(Contratos[ctfechafinreal])=TRUE() || Contratos[ctfechafinreal]>=[fecinianyo]))
		formatString: 0
		lineageTag: dc55f370-26e5-4701-ba83-95ff336d479b

	measure AvAnyoWeek = CALCULATE(AVERAGEX(VALUES(Calendario[Date]),[Asignaciones]),ALL(Calendario[Mes (Número)]))
		formatString: 0.00
		lineageTag: e66f913c-4c24-45d3-8b76-a9ee2921e756

