	partition contratos-fae9dbf6-6c52-4dc5-9f89-294c0bf13929 = m
		mode: import
		source =
				let
				    Source = Sql.Database("10.10.138.5\TEMPORING", "no3001", [Query="select ctcentro,ctcliente,ctcencli,ctcontrato,cttrabajador,ctfechaini,ctfechafinreal,cthorasdia,cthorassemana,ctcatepuesto,ctcatesalario,trnif#(lf)from contra inner join#(lf)#(tab)clientes on contra.ctempresa=clientes.clempresa and contra.ctcentro=clientes.clcentro and contra.ctcliente=clientes.clcodigo inner join#(lf)#(tab)trabajador on contra.ctempresa=trabajador.trempresa and contra.cttrabajador=trabajador.trtrabajador#(lf)where contra.ctempresa=1#(lf)and ((ctfechafinreal is null) or (year(ctfechafinreal)>=2021))#(lf)and clientes.clnombre not like '%fijo%'"]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(Source,{{"ctcentro", Int64.Type}, {"ctcencli", Int64.Type}})
				in
				    #"Tipo cambiado"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegación

