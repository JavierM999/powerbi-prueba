	column hifechamd
		dataType: dateTime
		formatString: General Date
		lineageTag: 27dceaf2-5c02-4bc3-8f2a-e640f5d12ab3
		summarizeBy: none
		sourceColumn: hifechamd

		annotation SummarizationSetBy = Automatic

	column importe
		dataType: double
		lineageTag: 383ecf48-c453-427e-ae5b-92705c27f96a
		summarizeBy: sum
		sourceColumn: importe

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column MiImport = IF([hitipo]="D",[importe]*-1,[importe])
		lineageTag: 296a4292-5d27-4ee0-b36a-0facb5307e7d
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition CnHistor = m
		mode: import
		source =
				let
				    Origen = Sql.Database("10.10.138.5\TEMPORING", "n4db003", [Query=" select hidelegacion,hiseccion,hicuenta,hidocum,hitipo, hifechamd,sum(hiimporte) as importe#(lf)  from cnhistor#(lf)  Where hifechamd>='01/01/2021'#(lf) and hiconcep<> 'Asiento Regularización'#(lf)  group by hidelegacion,hiseccion,hicuenta,hidocum,hitipo, hifechamd"]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(Origen,{{"hicuenta", Int64.Type}}),
				    #"Valor reemplazado" = Table.ReplaceValue(#"Tipo cambiado",96,99,Replacer.ReplaceValue,{"hiseccion"}),
				    #"Valor reemplazado1" = Table.ReplaceValue(#"Valor reemplazado",97,98,Replacer.ReplaceValue,{"hiseccion"})
				in
				    #"Valor reemplazado1"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navegación

