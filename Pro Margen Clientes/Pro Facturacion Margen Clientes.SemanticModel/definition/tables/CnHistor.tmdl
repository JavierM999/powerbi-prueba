table CnHistor
	lineageTag: 9be963e9-d816-426e-a96c-221b6f8c0e9f

	measure 'Servicos de Selección' = CALCULATE((CALCULATE(SUM(CnHistor[MiImport]),CnHistor[hicuenta]>= 7050010000,CnHistor[hicuenta]<= 7050019999)))
		formatString: #,0.00
		lineageTag: ddfdecfb-1513-4de1-bf9d-711efa2ded87

	column hidelegacion
		dataType: int64
		formatString: 0
		lineageTag: 977fa619-98e7-4f05-95cb-e15a7266f30a
		summarizeBy: sum
		sourceColumn: hidelegacion

		annotation SummarizationSetBy = Automatic

	column hiseccion
		dataType: double
		lineageTag: 27fcf10f-e73b-425d-828f-2db2322723e6
		summarizeBy: none
		sourceColumn: hiseccion

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column hicuenta
		dataType: int64
		formatString: 0
		lineageTag: b3d94195-004b-40b7-8858-aca6f452cc5a
