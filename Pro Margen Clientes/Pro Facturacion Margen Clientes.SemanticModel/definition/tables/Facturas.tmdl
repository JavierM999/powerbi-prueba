	measure 'Fra.Año Act' = CALCULATE([TotFraf],FILTER(Facturas,Facturas[fcfecha]>=[fecini]),FILTER(Facturas,Facturas[fcfecha]<=[fecfin]))
		lineageTag: a6796435-3e1b-4625-abd1-b9528823b44a

