	measure TotFra = CALCULATE(SUM(Facturas[fcbruto]),FILTER(Facturas,Facturas[fcfecha]>=[fecini]),FILTER(Facturas,Facturas[fcfecha]<=[fecfin]))
		lineageTag: ae6f19c5-fbf3-4fe2-9177-38d840a36d1b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Abonos = CALCULATE([TotFra],FILTER(Facturas,Facturas[fcbruto]<0))
		lineageTag: 3ad6a2eb-197b-4278-b3a2-ee0d5ddbb291

