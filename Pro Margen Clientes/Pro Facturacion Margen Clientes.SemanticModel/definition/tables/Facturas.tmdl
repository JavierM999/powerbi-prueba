	measure TotFraf = SUM(Facturas[fcbruto])
		lineageTag: e421ca23-3ac3-46b8-9cab-99d52fa1a621

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Clientes Nuevos' = ```
			
			IF(NOT(MIN(Calendario[Date]) > CALCULATE(MAX(Facturas[fcfecha]), ALL(Facturas))),
			    VAR primeraFecha = FIRSTDATE(Calendario[Date])
			    VAR tabla = FILTER(
			                        ALL(Calendario),
			                        Calendario[Date] >= DATEADD(primeraFecha, -5, YEAR) && Calendario[Date] <= MAX(Calendario[Date]) 
			                    )
			    RETURN
			    COUNTROWS(
			        FILTER(
			            ADDCOLUMNS(
			                CALCULATETABLE(
			                    VALUES(Facturas[FaCenCli]),
			                    tabla
			                ),
			                "FechaPrimFactura", CALCULATE(MIN(Facturas[fcfecha]), tabla)
			            ),
			            [FechaPrimFactura] >= primeraFecha
			        )
			    )
			)
			```
		formatString: 0
		lineageTag: c2e3c11c-5c68-426f-a492-b8a23d282280

