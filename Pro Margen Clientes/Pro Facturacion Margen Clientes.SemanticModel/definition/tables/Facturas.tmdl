		source =
				let
				    Origen = Sql.Database("10.10.138.5\TEMPORING", "no3001", [Query="select fccentro,fcserie,fcano,fcdocum,fcfecha,fccliente,fccencli,fcvendedor,clientes.clcifdni,fcbruto #(lf)from facturas inner join#(lf)#(tab)clientes on facturas.fcempresa=clientes.clempresa and facturas.fccentro=clientes.clcentro and facturas.fccliente=clientes.clcodigo#(lf)where fcempresa=1#(lf)and fcano>=2021"]),
