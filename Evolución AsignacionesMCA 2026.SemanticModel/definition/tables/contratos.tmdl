	measure TrabActivos =
			
			CALCULATE (
			        DISTINCTCOUNT(contratos[cttrabajador]),
			        FILTER ( ALL ( contratos[ctfechaini] ), Contratos[ctfechaini] <= [fecfin] ),
			        FILTER (
			            ALL ( contratos[ctfechafinreal] ),
			            ISBLANK ( Contratos[ctfechafinreal] ) = TRUE ()
			                || Contratos[ctfechafinreal] >= [fecini]
			        )
			    )
		formatString: 0
		lineageTag: f25273ec-469c-4914-b68c-ea18ecc855c7

	measure 'Horas Realizadas' =
			
			VAR result = sumx (
			    CALCULATETABLE(
			      ADDCOLUMNS(
			        SUMMARIZE(Contratos,Contratos[ctcentro],Contratos[ctcliente],Contratos[ctcontrato],Contratos[cthorassemana],Contratos[ctfechaini],Contratos[ctfechafinreal]),
			    "fini",IF(Contratos[ctfechaini]<[fecini],[fecini],Contratos[ctfechaini]),
			    "ffin",IF(ISBLANK(Contratos[ctfechafinreal])=TRUE() || Contratos[ctfechafinreal]>=[fecfin],[fecfin],Contratos[ctfechafinreal])),
			    FILTER(Contratos,Contratos[ctfechaini]<=[fecfin]),FILTER(Contratos,  ISBLANK(Contratos[ctfechafinreal])=TRUE() || Contratos[ctfechafinreal]>=[fecini])),
			        DIVIDE((DATEDIFF([fini],[ffin],DAY)+1),7)*Contratos[cthorassemana])
			RETURN result
		formatString: #,0.00
		lineageTag: ec2e49ff-4422-4d01-8538-9334286e4b46

