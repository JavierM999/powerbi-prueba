	measure 'Max.Asignac' =
			
			VAR fecha_inicio = [fecini]
			VAR fecha_fin_ajustada = [fecfinay2]
			RETURN
			    CALCULATE (
			        MAXX ( VALUES ( Calendario[Date] ), [Asignaciones] ),
			        FILTER (
			            ALL(Calendario),
			            Calendario[Date] >= fecha_inicio
			                && Calendario[Date] <= fecha_fin_ajustada
			        )
			    )
		formatString: 0
		lineageTag: d957e49c-5d5a-4468-8fa9-0ec425a8d153

	measure 'Min.Asignac' =
			
			VAR fecha_inicio = [fecini]
			VAR fecha_fin_ajustada = [fecfinay]
			RETURN
			    CALCULATE (
			        MINX ( VALUES ( Calendario[Date] ), [Asignaciones] ),
			        FILTER (
			            Calendario,
			            Calendario[Date] >= fecha_inicio
			                && Calendario[Date] <= fecha_fin_ajustada
			        )
			    )
		formatString: 0
		lineageTag: c54b683a-2d08-4d8c-be5d-1676495d0acc

	measure ActivosHoy =
			
			CALCULATE (
			        COUNTROWS ( Contratos ),
			        FILTER ( ALL ( contratos[ctfechaini] ), Contratos[ctfechaini] <= TODAY()),
			        FILTER (
			            ALL ( contratos[ctfechafinreal] ),
			            ISBLANK ( Contratos[ctfechafinreal] ) = TRUE ()
			                || Contratos[ctfechafinreal] >= TODAY()
			        )
			    )
		formatString: 0
		lineageTag: 3f40ba71-b659-4817-8777-70bab9172a04

	measure 'Max.Asignac2' = ```
			
			VAR fecha_inicio = [fecini]
			VAR fecha_fin_ajustada = [fecfinay2]
			VAR fecha_seleccionada = SELECTEDVALUE(Calendario[Date])
			RETURN
			    CALCULATE (
			        MAXX ( VALUES ( Calendario[Date] ), [Asignaciones] ),
			        FILTER (
			            ALL(Calendario),  // Elimina el filtro de fecha de la segmentación
			            Calendario[Date] >= fecha_inicio
			                && Calendario[Date] <= fecha_fin_ajustada
			                && Calendario[Date] <> fecha_seleccionada  // Ignora la fecha seleccionada
			        )
			    )
			
			```
		formatString: 0
		lineageTag: a92d6b9f-737f-4643-8846-1411f4a124d1

