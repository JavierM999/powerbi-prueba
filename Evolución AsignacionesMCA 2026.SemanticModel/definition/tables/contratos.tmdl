	measure 'Trabajadores Nuevos' = ```
			
			VAR FechaInicioPeriodo = [fecini]           
			VAR FechaFinPeriodo = [fecfin]              
			VAR FechaInicioHistorico = DATE(YEAR(FechaInicioPeriodo) - 3, MONTH(FechaInicioPeriodo), DAY(FechaInicioPeriodo))
			VAR FechaFinHistorico = FechaInicioPeriodo - 1
			
			-- Lista completa de trabajadores (desde la tabla principal)
			VAR ListaTrabajadores = VALUES(Trabajadores[cttrabajador])
			
			-- Filtrar trabajadores con contratos activos en el período actual
			VAR Trabajadores_Activos_Periodo = 
			    FILTER(
			        ListaTrabajadores,
			        CALCULATE(
			            COUNTROWS(Contratos),
			            FILTER(
			                ALL(Contratos),
			                Contratos[cttrabajador] = EARLIER(Trabajadores[cttrabajador]) &&
			                Contratos[ctfechaini] <= FechaFinPeriodo &&
			                (ISBLANK(Contratos[ctfechafinreal]) || Contratos[ctfechafinreal] >= FechaInicioPeriodo)
			            )
			        ) > 0
			    )
			
			-- Filtrar trabajadores con contratos activos en el histórico
			VAR Trabajadores_Historico = 
			    FILTER(
			        ListaTrabajadores,
			        CALCULATE(
			            COUNTROWS(Contratos),
			            FILTER(
			                ALL(Contratos),
			                Contratos[cttrabajador] = EARLIER(Trabajadores[cttrabajador]) &&
			                Contratos[ctfechaini] <= FechaFinHistorico &&
			                (ISBLANK(Contratos[ctfechafinreal]) || Contratos[ctfechafinreal] >= FechaInicioHistorico)
			            )
			        ) > 0
			    )
			
			-- Excluir los que ya estaban en el histórico
			VAR Nuevos_Trabajadores = 
			    EXCEPT(Trabajadores_Activos_Periodo, Trabajadores_Historico)
			
			RETURN
			COUNTROWS(Nuevos_Trabajadores)
			
			
			```
		formatString: 0
		lineageTag: d2ad31f5-c38c-4c55-a8a5-7beb7ed02bbb

	measure EsTrabajadorNuevo = ```
			
			VAR FechaInicioPeriodo = [fecini]           
			VAR FechaFinPeriodo = [fecfin]              
			VAR FechaInicioHistorico = DATE(YEAR(FechaInicioPeriodo) - 3, MONTH(FechaInicioPeriodo), DAY(FechaInicioPeriodo))
			
			VAR TrabajadorActual = SELECTEDVALUE(Contratos[cttrabajador])
			
			-- ¿Está activo en el período seleccionado?
			VAR ActivoEnPeriodo = 
			    CALCULATE(
			        COUNTROWS(Contratos),
			        FILTER(
			            ALL(Contratos),
			            Contratos[cttrabajador] = TrabajadorActual &&
			            Contratos[ctfechaini] <= FechaFinPeriodo &&
			            (ISBLANK(Contratos[ctfechafinreal]) || Contratos[ctfechafinreal] >= FechaInicioPeriodo)
			        )
			    ) > 0
			
			-- ¿Tuvo contratos en los 3 años anteriores?
			VAR TieneHistorico = 
			    CALCULATE(
			        COUNTROWS(Contratos),
			        FILTER(
			            ALL(Contratos),
			            Contratos[cttrabajador] = TrabajadorActual &&
			            Contratos[ctfechaini] <= FechaInicioPeriodo - 1 &&
			            (ISBLANK(Contratos[ctfechafinreal]) || Contratos[ctfechafinreal] >= FechaInicioHistorico)
			        )
			    ) > 0
			
			RETURN
			IF(ActivoEnPeriodo && NOT TieneHistorico, 1, BLANK())
			
			```
		formatString: 0
		lineageTag: 6fcdc12e-3a96-4ce2-aefc-4d15a19ab4e6

	measure Filtro_Nuevos = ```
			
			VAR FechaInicioPeriodo = [fecini]           
			VAR FechaFinPeriodo = [fecfin]              
			VAR FechaInicioHistorico = DATE(YEAR(FechaInicioPeriodo) - 3, MONTH(FechaInicioPeriodo), DAY(FechaInicioPeriodo))
			VAR FechaFinHistorico = FechaInicioPeriodo - 1
			
			VAR TrabajadorActual = SELECTEDVALUE(Trabajadores[cttrabajador])
			
			VAR ActivoEnPeriodo = 
			    CALCULATE(
			        COUNTROWS(Contratos),
			        FILTER(
			            ALL(Contratos),
			            Contratos[cttrabajador] = TrabajadorActual &&
			            Contratos[ctfechaini] <= FechaFinPeriodo &&
			            (ISBLANK(Contratos[ctfechafinreal]) || Contratos[ctfechafinreal] >= FechaInicioPeriodo)
			        )
			    ) > 0
			
			VAR TieneHistorico = 
			    CALCULATE(
			        COUNTROWS(Contratos),
			        FILTER(
			            ALL(Contratos),
			            Contratos[cttrabajador] = TrabajadorActual &&
			            Contratos[ctfechaini] <= FechaFinHistorico &&
			            (ISBLANK(Contratos[ctfechafinreal]) || Contratos[ctfechafinreal] >= FechaInicioHistorico)
			        )
			    ) > 0
			
			RETURN
			IF(ActivoEnPeriodo && NOT TieneHistorico, 1, BLANK())
			
			```
