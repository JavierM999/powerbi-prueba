	partition DunClien-4dd30820-1cbb-410f-9b8d-e359ee6cd729 = m
		mode: import
		source =
				let
				    Source = Sql.Database("10.10.138.5\TEMPORING", "no3004", [Query="Select distinct clientes.clcentro,clientes.clcodigo,clientes.clnombre,clientes.clcifdni,min(cencli.cclcnae) as cclcnae,min(cencli.cclconvenio) as cclconvenio#(lf)from                       clientes inner join#(lf)        contra on clientes.clempresa=contra.ctempresa and clientes.clcentro=contra.ctcentro and clientes.clcodigo =contra.ctcliente inner join#(lf)#(tab)#(tab)cencli on contra.ctempresa=cencli.cclempresa and contra.ctcentro=cencli.cclcentro and contra.ctcliente =cencli.cclcodigo #(lf)#(tab)#(tab)            and contra.ctcencli=cencli.cclcentrocliente#(lf)where clientes.clempresa=04#(lf)and ((contra.ctfechafinreal is null) or year(contra.ctfechafinreal)>=2019)#(lf)ANd clcentro <> 9999#(lf)group by clientes.clcentro,clientes.clcodigo,clientes.clnombre,clientes.clcifdni"]),
				    #"Filas filtradas" = Table.SelectRows(Source, each true),
				    #"Tipo cambiado" = Table.TransformColumnTypes(#"Filas filtradas",{{"clcentro", Int64.Type}, {"cclconvenio", Int64.Type}})
				in
				    #"Tipo cambiado"

