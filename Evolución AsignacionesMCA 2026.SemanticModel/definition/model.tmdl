model Model
	culture: es-ES
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-ES
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["contratos","MCANCentros","Clientes","Categorias","Trabajadores","Duncontra","DunClien","DunCatego","DunTrabaj","NonoContra","BWContra","IntContra","TipContra"]

annotation PBI_ProTooling = ["DevMode"]

ref table contratos
ref table Calendario
ref table MCANCentros
ref table Clientes
ref table Categorias
ref table Trabajadores
ref table Duncontra
ref table DunClien
ref table DunCatego
ref table DunTrabaj
ref table NonoContra
ref table BWContra
ref table IntContra
ref table TipContra
ref table Tabla_Fechas

ref cultureInfo es-ES

